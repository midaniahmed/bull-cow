{
  "name": "@bc/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@bc/shared": "workspace:*",
    "fastify": "^5.1.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "socket.io": "^4.8.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "ioredis": "^5.4.1",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5",
    "async-lock": "^1.4.1",
    "zod": "^3.23.8",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@types/async-lock": "^1.4.2",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
